#Solve Move Zeroes using two-pointer approach swapping method
nums = [0,1,0,3,12,0,0,11,0,9]
# nums = [1,2,3]
def moves_zero(nums):
    i=0
    j=0
    while i<len(nums):
        if nums[i]==0:
            i=i+1
        else:
            t=nums[j]
            nums[j]=nums[i]
            nums[i]=t
            i=i+1
            j=j+1
    return nums
print(moves_zero(nums))
